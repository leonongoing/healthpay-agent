# HealthPay Reconciliation Agent Configuration

# FHIR Server
HEALTHPAY_FHIR_SERVER_URL=http://localhost:19911/fhir

# LLM Provider Priority (gemma4 | 0g | openai)
# Default: gemma4 (for Kaggle Gemma 4 Good Hackathon compliance)
HEALTHPAY_LLM_PROVIDER=gemma4

# Gemma 4 Configuration (Google AI Studio)
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMMA4_MODEL=gemma-4-27b-it
GEMMA4_TEMPERATURE=0.3
GEMMA4_MAX_TOKENS=4096

# 0G Storage (for audit trail)
ZG_PRIVATE_KEY=0x_your_ethereum_private_key_here
ZG_EVM_RPC=https://evmrpc-testnet.0g.ai
ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# 0G Compute (for AI inference)
ZG_COMPUTE_PRIVATE_KEY=0x_your_ethereum_private_key_here
ZG_COMPUTE_MODEL=Qwen/Qwen2.5-7B-Instruct
ZG_COMPUTE_NETWORK=testnet

# OpenAI Fallback
OPENAI_API_KEY=sk-your-openai-key-here
